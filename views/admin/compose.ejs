<!DOCTYPE html>
<html lang="en" data-bs-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Documentation - bDoci</title>
    <link rel="icon" type="image/x-icon" href="logo/bimbokdocs.ico">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --primary-color: #3b82f6;
            --sidebar-width: 280px;
            --font-family: 'Inter', system-ui, -apple-system, sans-serif;
            --code-font: 'Fira Code', monospace;
        }

        [data-bs-theme="dark"] {
            --bs-body-bg: #0f172a;
            --bs-body-color: #f8fafc;
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bs-body-bg);
            transition: background-color 0.3s ease;
        }

        /* Sidebar Styling (Matches Site) */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            padding-top: 1.5rem;
            border-right: 1px solid rgba(0,0,0,0.05);
            background: var(--bs-body-bg);
            transition: transform 0.3s ease;
        }

        [data-bs-theme="dark"] .sidebar { border-right-color: rgba(255,255,255,0.05); }

        .main-content {
            margin-left: var(--sidebar-width);
            padding: 3rem 2rem;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        @media (max-width: 991.98px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 5rem 1rem 2rem 1rem; }
        }

        .nav-link {
            padding: 0.75rem 1.25rem;
            color: var(--bs-body-color);
            border-radius: 0.5rem;
            margin: 0.25rem 1rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--primary-color);
        }

        .category-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            font-weight: 700;
            padding: 0 2rem;
            margin-bottom: 0.75rem;
        }

        /* Form Styling */
        .form-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .card {
            border: none;
            border-radius: 1.25rem;
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            background: var(--bs-body-bg);
            border: 1px solid rgba(0,0,0,0.05);
        }

        [data-bs-theme="dark"] .card { border-color: rgba(255,255,255,0.05); }

        .form-label { font-weight: 600; color: #475569; margin-bottom: 0.5rem; }
        [data-bs-theme="dark"] .form-label { color: #94a3b8; }

        .form-control, .form-select {
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(0,0,0,0.1);
            background: var(--bs-body-bg);
        }

        [data-bs-theme="dark"] .form-control, [data-bs-theme="dark"] .form-select {
            border-color: rgba(255,255,255,0.1);
        }

        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            border-color: var(--primary-color);
        }

        .code-textarea { font-family: var(--code-font); font-size: 0.95rem; }

        .btn-primary {
            padding: 0.75rem 2rem;
            border-radius: 0.75rem;
            font-weight: 600;
            background: var(--primary-color);
            border: none;
        }

        /* Top Actions */
        .top-actions {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 1001;
            display: flex;
            gap: 0.75rem;
        }

        .action-btn {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bs-body-bg);
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            color: inherit;
            transition: all 0.2s;
        }
    </style>
</head>

<body>
    <!-- Top Actions -->
    <div class="top-actions">
        <button class="action-btn d-lg-none" id="mobileToggle">
            <i class="bi bi-list"></i>
        </button>
        <button class="action-btn" id="themeToggle">
            <i class="bi bi-sun-fill" id="themeIcon"></i>
        </button>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="px-4 mb-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="logo/bimbokdocs.ico" width="32" height="32" alt="bDoci Logo">
                <span class="h4 mb-0 fw-bold">bDoci</span>
            </a>
        </div>

        <div class="category-label">Admin</div>
        <nav class="nav flex-column mb-4">
            <a class="nav-link active" href="/admin">
                <i class="bi bi-plus-square me-2"></i> Create Doc
            </a>
            <a class="nav-link" href="/">
                <i class="bi bi-house me-2"></i> Home View
            </a>
        </nav>

        <div class="category-label">Existing Categories</div>
        <nav class="nav flex-column overflow-y-auto" style="max-height: calc(100vh - 300px);">
            <% categories.forEach(function(cat) { %>
                <div class="nav-link text-muted small">
                    <i class="bi bi-folder2 me-2"></i> <%= cat %>
                </div>
            <% }); %>
        </nav>
    </aside>

    <main class="main-content">
        <div class="form-container">
            <div class="mb-4">
                <h1 class="fw-bold h2">Create New Documentation</h1>
                <p class="text-muted">Fill in the details below to publish a new document.</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <form action="/compose" method="post">
                        <div class="mb-4">
                            <label for="title" class="form-label">Document Title</label>
                            <input type="text" class="form-control form-control-lg" id="title" name="title"
                                placeholder="e.g., Introduction to API v2" required>
                        </div>

                        <div class="mb-4">
                            <label for="category" class="form-label">Category</label>
                            <div class="row g-2">
                                <div class="col-sm-6">
                                    <select class="form-select" id="category" name="category">
                                        <option value="">Select Category...</option>
                                        <% categories.forEach(function(cat) { %>
                                            <option value="<%= cat %>"><%= cat %></option>
                                        <% }); %>
                                        <option value="new">+ Add New Category</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <input type="text" class="form-control" id="newCategory" name="newCategory" 
                                        placeholder="Enter new category name..." style="display: none;">
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="doc" class="form-label">Documentation Content (HTML supported)</label>
                            <textarea class="form-control" id="doc" name="doc" rows="10"
                                placeholder="Describe the documentation here..." required></textarea>
                        </div>

                        <div class="mb-4">
                            <label for="code" class="form-label">Code Snippet (Optional)</label>
                            <textarea class="form-control code-textarea" id="code" name="code" rows="8"
                                placeholder="Paste relevant code here..." spellcheck="false"></textarea>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-cloud-upload me-2"></i> Publish Document
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Theme Toggle
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const html = document.documentElement;
        
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', savedTheme);
        updateThemeIcon(savedTheme);
        
        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            html.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });
        
        function updateThemeIcon(theme) {
            themeIcon.className = theme === 'light' ? 'bi bi-moon-fill' : 'bi bi-sun-fill';
        }

        // Sidebar Mobile Toggle
        const mobileToggle = document.getElementById('mobileToggle');
        const sidebar = document.getElementById('sidebar');
        mobileToggle.addEventListener('click', () => sidebar.classList.toggle('show'));

        // Category Logic
        document.getElementById('category').addEventListener('change', function () {
            const newCategoryInput = document.getElementById('newCategory');
            if (this.value === 'new') {
                newCategoryInput.style.display = 'block';
                newCategoryInput.setAttribute('required', 'true');
            } else {
                newCategoryInput.style.display = 'none';
                newCategoryInput.removeAttribute('required');
            }
        });
    </script>
</body>

</html>