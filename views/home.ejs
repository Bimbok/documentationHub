<!DOCTYPE html>
<html lang="en" data-bs-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>bDoci - Documentation Hub</title>
    <link rel="icon" type="image/x-icon" href="logo/bimbokdocs.ico">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --primary-color: #3b82f6;
            --primary-hover: #2563eb;
            --sidebar-width: 280px;
            --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --card-shadow-hover: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        [data-bs-theme="dark"] {
            --bs-body-bg: #0f172a;
            --bs-body-color: #f8fafc;
            --card-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.3);
        }

        body {
            font-family: var(--font-family);
            background-color: var(--bs-body-bg);
            transition: background-color 0.3s ease;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            padding-top: 1.5rem;
            border-right: 1px solid rgba(0,0,0,0.05);
            background: var(--bs-body-bg);
            transition: transform 0.3s ease, background-color 0.3s ease;
        }

        [data-bs-theme="dark"] .sidebar {
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        @media (max-width: 991.98px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
        }

        .nav-link {
            padding: 0.75rem 1.25rem;
            color: var(--bs-body-color);
            border-radius: 0.5rem;
            margin: 0.25rem 1rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--primary-color);
        }

        .nav-link.active {
            background-color: var(--primary-color);
            color: white !important;
        }

        /* Card Styling */
        .doc-card {
            border: none;
            border-radius: 1rem;
            box-shadow: var(--card-shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            overflow: hidden;
            background: var(--bs-body-bg);
            border: 1px solid transparent;
        }

        [data-bs-theme="dark"] .doc-card {
            border: 1px solid rgba(255,255,255,0.05);
        }

        .doc-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--card-shadow-hover);
            border-color: var(--primary-color);
        }

        .doc-card .card-title {
            font-weight: 600;
            margin-bottom: 0.75rem;
        }

        .doc-card .card-text {
            color: #64748b;
            font-size: 0.95rem;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        [data-bs-theme="dark"] .doc-card .card-text {
            color: #94a3b8;
        }

        /* Search Box */
        .search-container {
            position: sticky;
            top: 0;
            z-index: 50;
            background: rgba(var(--bs-body-bg-rgb), 0.8);
            backdrop-filter: blur(12px);
            margin: -2rem -2rem 2rem -2rem;
            padding: 1.5rem 2rem;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        [data-bs-theme="dark"] .search-container {
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        @media (max-width: 991.98px) {
            .search-container {
                padding-right: 8.5rem; /* Space for top-actions on mobile */
                padding-left: 1.5rem;
            }
        }

        .search-input-wrapper {
            max-width: 600px;
            position: relative;
        }

        .search-input-wrapper .form-control {
            padding-left: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(0,0,0,0.1);
            background: var(--bs-body-bg);
            box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        }

        [data-bs-theme="dark"] .search-input-wrapper .form-control {
            border-color: rgba(255,255,255,0.1);
        }

        .search-input-wrapper i {
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
        }

        /* Theme Toggle & Mobile Toggle */
        .top-actions {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 1001;
            display: flex;
            gap: 0.75rem;
        }

        .action-btn {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bs-body-bg);
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: var(--card-shadow);
            color: var(--bs-body-color);
            transition: all 0.2s ease;
        }

        @media (max-width: 575.98px) {
            .top-actions {
                top: 1.25rem;
                right: 1rem;
                gap: 0.5rem;
            }
            .action-btn {
                width: 2.75rem;
                height: 2.75rem;
            }
            .search-container {
                padding-right: 7.5rem;
            }
        }

        [data-bs-theme="dark"] .action-btn {
            border-color: rgba(255,255,255,0.1);
        }

        .action-btn:hover {
            background: var(--primary-color);
            color: white;
            transform: scale(1.05);
        }

        .category-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            font-weight: 700;
            padding: 0 2rem;
            margin-bottom: 0.75rem;
        }

        .no-results {
            display: none;
            padding: 4rem 2rem;
            text-align: center;
        }

        .no-results i {
            font-size: 3rem;
            color: #94a3b8;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body>
    <!-- Top Actions -->
    <div class="top-actions">
        <button class="action-btn d-lg-none" id="mobileToggle">
            <i class="bi bi-list"></i>
        </button>
        <button class="action-btn" id="themeToggle">
            <i class="bi bi-sun-fill" id="themeIcon"></i>
        </button>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="px-4 mb-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="logo/bimbokdocs.ico" width="32" height="32" alt="bDoci Logo">
                <span class="h4 mb-0 fw-bold">bDoci</span>
            </a>
        </div>

        <div class="category-label">Navigation</div>
        <nav class="nav flex-column mb-4">
            <a class="nav-link active category-badge" href="#" data-category="all">
                <i class="bi bi-grid me-2"></i> All Docs
            </a>
            <a class="nav-link" href="/admin">
                <i class="bi bi-shield-lock me-2"></i> Admin Panel
            </a>
        </nav>

        <div class="category-label">Categories</div>
        <nav class="nav flex-column overflow-y-auto" style="max-height: calc(100vh - 300px);">
            <% categories.forEach(function(cat) { %>
                <a class="nav-link category-badge" href="#" data-category="<%= cat %>">
                    <i class="bi bi-folder2 me-2"></i> <%= cat %>
                </a>
            <% }); %>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Search Header -->
        <header class="search-container">
            <div class="search-input-wrapper">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control" id="searchInput"
                    placeholder="Search documentation, guides, or snippets..." autocomplete="off">
            </div>
        </header>

        <!-- Documentation Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4" id="docsGrid">
            <% if (documents && documents.length > 0) { %>
                <% documents.forEach(function(doc) { %>
                    <div class="col doc-item" data-category="<%= doc.category || 'Uncategorized' %>">
                        <div class="card doc-card h-100"
                            onclick="window.location.href='/<%= doc.title %>'">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1">
                                        <%= doc.category || 'Uncategorized' %>
                                    </span>
                                </div>
                                <h5 class="card-title text-truncate" title="<%= doc.title %>">
                                    <%= doc.title %>
                                </h5>
                                <p class="card-text">
                                    <%= doc.document.substring(0, 150) %>...
                                </p>
                            </div>
                            <div class="card-footer bg-transparent border-0 px-4 pb-4">
                                <div class="d-flex align-items-center gap-2 text-muted small">
                                    <i class="bi bi-book"></i>
                                    <span>Read More</span>
                                    <% if (doc.code && doc.code.trim().length > 0) { %>
                                        <span class="ms-auto text-primary">
                                            <i class="bi bi-code-slash"></i> Code
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <div class="alert alert-info py-4 rounded-4 border-0 shadow-sm">
                        <i class="bi bi-info-circle-fill d-block mb-3 fs-1 opacity-50"></i>
                        <h5>No documentation found</h5>
                        <p class="mb-0 text-muted">Get started by creating your first document in the admin panel.</p>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- No Results Message -->
        <div class="no-results" id="noResults">
            <i class="bi bi-search"></i>
            <h3>No matching results</h3>
            <p class="text-muted">Try adjusting your search terms or filters.</p>
        </div>
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Theme Toggle Logic
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const html = document.documentElement;

        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', savedTheme);
        updateThemeIcon(savedTheme);

        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            html.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });

        function updateThemeIcon(theme) {
            themeIcon.className = theme === 'light' ? 'bi bi-moon-fill' : 'bi bi-sun-fill';
        }

        // Mobile Sidebar Toggle
        const mobileToggle = document.getElementById('mobileToggle');
        const sidebar = document.getElementById('sidebar');

        mobileToggle.addEventListener('click', () => {
            sidebar.classList.toggle('show');
        });

        // Close sidebar on click outside (mobile)
        document.addEventListener('click', (e) => {
            if (window.innerWidth < 992 && !sidebar.contains(e.target) && !mobileToggle.contains(e.target)) {
                sidebar.classList.remove('show');
            }
        });

        // Search & Filter functionality
        const searchInput = document.getElementById('searchInput');
        const noResults = document.getElementById('noResults');
        const docItems = document.querySelectorAll('.doc-item');
        const categoryBadges = document.querySelectorAll('.category-badge');

        let currentCategory = 'all';
        let currentSearchTerm = '';

        categoryBadges.forEach(badge => {
            badge.addEventListener('click', function (e) {
                e.preventDefault();
                const category = this.getAttribute('data-category');

                categoryBadges.forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                currentCategory = category;
                filterDocuments();
                
                if (window.innerWidth < 992) sidebar.classList.remove('show');
            });
        });

        searchInput.addEventListener('input', function (e) {
            currentSearchTerm = e.target.value.toLowerCase();
            filterDocuments();
        });

        function filterDocuments() {
            let hasResults = false;

            docItems.forEach(item => {
                const itemCategory = item.getAttribute('data-category');
                const title = item.querySelector('.card-title').textContent.toLowerCase();
                const content = item.querySelector('.card-text').textContent.toLowerCase();

                const categoryMatch = currentCategory === 'all' || itemCategory === currentCategory;
                const searchMatch = currentSearchTerm === '' ||
                    title.includes(currentSearchTerm) ||
                    content.includes(currentSearchTerm);

                if (categoryMatch && searchMatch) {
                    item.style.display = '';
                    hasResults = true;
                } else {
                    item.style.display = 'none';
                }
            });

            noResults.style.display = hasResults ? 'none' : 'block';
        }
    </script>
</body>

</html>